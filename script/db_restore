#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/.."

RAILS_ENV="live"
DUMP_FILE="${1:?Usage: script/db_restore backups/some_file.dump}"

DB_NAME="$(bin/rails runner -e "$RAILS_ENV" 'print ActiveRecord::Base.connection_db_config.database')"

echo "This will replace database: $DB_NAME"
echo "Using dump: $DUMP_FILE"
read -p "Type RESTORE to continue: " CONFIRM

if [ "$CONFIRM" != "RESTORE" ]; then
  echo "Aborted."
  exit 1
fi

echo "Backing up current state before restoring over it..."
script/db_backup

echo "Terminating other connections to $DB_NAME..."
psql -d postgres -c "
  SELECT pg_terminate_backend(pid)
  FROM pg_stat_activity
  WHERE datname = '${DB_NAME}' AND pid <> pg_backend_pid();
" >/dev/null

DISABLE_DATABASE_ENVIRONMENT_CHECK=1 bin/rails db:drop db:create RAILS_ENV="$RAILS_ENV"

pg_restore \
  --clean \
  --if-exists \
  --no-owner \
  --dbname="$DB_NAME" \
  "$DUMP_FILE"

echo "Restored $DB_NAME from $DUMP_FILE"
